# ============================================================
# T-GYM — variables d'environnement
# Copier ce fichier en .env (jamais commité) et remplir les valeurs.
# Toutes les variables ci-dessous ont un comportement de repli sûr si
# elles sont absentes (sauf SECRET_KEY/DEBUG/ALLOWED_HOSTS en production,
# voir les avertissements).
# ============================================================


# --- Django — cœur du projet ---------------------------------

# Clé secrète Django. En local, une valeur par défaut de dev est utilisée
# si absente (préfixée "django-insecure-"). En production, à fournir
# OBLIGATOIREMENT — génère une vraie clé avec :
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=

# "True" en local, "False" en production (n'importe quelle autre valeur
# que la chaîne exacte "True" est traitée comme False).
DEBUG=True

# Domaines autorisés, séparés par des virgules, sans espace superflu.
# Vide = uniquement localhost/127.0.0.1 (suffisant en local avec DEBUG=True).
# Exemple production : ALLOWED_HOSTS=tgym.example.com,www.tgym.example.com
ALLOWED_HOSTS=


# --- Gemini — messages de relance (Étape 3) + chatbot du site (Étape 5) ---

# Sans cette clé : les deux fonctionnalités continuent de fonctionner en
# mode dégradé (message de secours pour les relances, réponse d'invitation
# à contacter WhatsApp pour le chatbot) — rien ne casse, mais rien n'est
# généré par l'IA non plus.
GEMINI_API_KEY=


# --- WhatsApp Business Cloud API — envoi automatique des relances (Étape 4) ---
# 🔒 Nécessite un compte Meta Business + un numéro dédié validé + un
# template pré-approuvé (voir WHATSAPP_TEMPLATE_RELANCE ci-dessous).
# Sans ACCESS_TOKEN et PHONE_NUMBER_ID : l'envoi automatique est
# simplement indisponible, les messages restent "à envoyer" pour copie
# manuelle par le staff dans l'admin — aucun blocage.

WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=

# Nom du template Meta pré-approuvé pour la relance d'abonnement (3
# variables attendues dans le corps du template, dans cet ordre :
# prénom, formule, date d'expiration). Doit être créé ET approuvé côté
# Meta Business Manager avant que l'envoi automatique fonctionne, même
# une fois les deux variables ci-dessus renseignées.
WHATSAPP_TEMPLATE_RELANCE=relance_abonnement

# Code langue du template (doit correspondre à la langue choisie lors de
# la création du template dans Meta Business Manager).
WHATSAPP_TEMPLATE_LANGUE=fr
